    <rdf:Description rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103/p">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103/e">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103/d">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Infiere pronóstico Favorable para paciente con SeLIE. Síndrome autolimitado de buen pronóstico, desarrollo neurológico normal conservado. Basado en ILAE 2022</rdfs:comment>
        <rdfs:label>Regla_Pronostico_SeLIE</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103/p"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneDiagnostico"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103/p"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#SeLIE_Diagnostico"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tienePronostico"/>
