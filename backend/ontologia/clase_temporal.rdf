        <rdfs:comment>Urgencia Alta: crisis migrantes casi continuas con deterioro neurológico rápido, requiere atención especializada urgente</rdfs:comment>
        <rdfs:label>Regla_Urgencia_EIMFS</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103/p"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneDiagnostico"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103/p"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#EIMFS_Diagnostico"/>
