<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103/"
     xml:base="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:untitled-ontology-103="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#presentaSigno -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#presentaSigno">
        <rdfs:range rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#SignoClinico"/>
        <rdfs:comment>Signos clínicos que presenta el paciente</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneDiagnostico -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneDiagnostico">
        <rdfs:range rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#SindromeEpileptico"/>
        <rdfs:comment>Relaciona un paciente con su diagnóstico de síndrome epiléptico</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneEtiologia -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneEtiologia">
        <rdfs:range rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Etiologia"/>
        <rdfs:comment>Etiología asociada al síndrome</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneNivelUrgencia -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneNivelUrgencia">
        <rdfs:range rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#NivelUrgencia"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tienePronostico -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tienePronostico">
        <rdfs:range rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Pronostico"/>
        <rdfs:comment>Pronóstico esperado del síndrome</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#asociadoFiebre -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#asociadoFiebre">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#complicacionPerinatal -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#complicacionPerinatal">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#duracionCrisisSegundos -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#duracionCrisisSegundos">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Duración promedio de las crisis en segundos</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#edadInicioEnDias -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#edadInicioEnDias">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Edad de inicio de las crisis en días de vida (0-90)</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#frecuenciaCrisisPorDia -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#frecuenciaCrisisPorDia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Número de crisis por día</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#lateralizacionCrisis -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#lateralizacionCrisis">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#puntuacionAPGAR -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#puntuacionAPGAR">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Apariencia (Color de la piel)
Pulso (Frecuencia cardíaca)
Gestos (Irritabilidad refleja)
Actividad (Tono muscular)
Respiración (Esfuerzo respiratorio)</rdfs:comment>
        <rdfs:comment>Puntuación APGAR al minuto 5 (0-10)</rdfs:comment>
        <rdfs:comment>evaluación clínica rápida utilizada a los poco minutos del nacimiento para valorar el estado fisiológico general del recién nacido</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#regresionDesarrollo -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#regresionDesarrollo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneAntecedenteFamiliar -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneAntecedenteFamiliar">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Antecedente familiar de epilepsia o convulsiones neonatales</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneCrisisClonicas -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneCrisisClonicas">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Presenta crisis clónicas</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneCrisisTonicas -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneCrisisTonicas">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Presenta crisis tónicas</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneEspasmos -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneEspasmos">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Presenta espasmos epilépticos</rdfs:comment>
        <rdfs:comment>presencia de contracciones musculares involuntarias, súbitas y breves.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneHipotonia -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneHipotonia">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Estado clínico caracterizado por la disminución del tono muscular</rdfs:comment>
        <rdfs:comment>Presenta hipotonía generalizada</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneMioclonias -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#tieneMioclonias">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/eliut/ontologies/2026/1/untitled-ontology-103#Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


